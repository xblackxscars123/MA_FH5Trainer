<Page x:Class="XPaint.Views.SubPages.SelfVehicle.Painter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:XPaint.Views.SubPages.SelfVehicle"
      xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance local:Painter, IsDesignTimeCreatable=True}"
      Title="Painter"
      d:DesignHeight="Auto"
      d:DesignWidth="800"
      Background="Transparent">

    <StackPanel>

        <!-- Initialize / Status -->
        <Border Style="{StaticResource CommonBorderStyle}">
            <StackPanel Margin="5 0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Initialize Painter"
                        IsEnabled="{Binding ViewModel.UiElementsEnabled, Mode=OneWay}"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        mah:ControlsHelper.FocusBorderThickness="0"
                        mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                        Background="{DynamicResource MahApps.Brushes.AccentBase}"
                        BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                        Command="{Binding ViewModel.InitializePainterCommand}"/>

                <Rectangle Margin="4 8" Width="1" VerticalAlignment="Stretch" Fill="White"/>

                <Label VerticalAlignment="Center" Content="Status:" Margin="0 0 5 0"/>

                <Label VerticalAlignment="Center"
                       Content="{Binding ViewModel.PainterInitialized, Converter={StaticResource BoolParamConverter}, ConverterParameter='Initialized|Not Initialized'}"
                       Foreground="{Binding ViewModel.PainterInitialized, Converter={StaticResource BoolParamConverter}, ConverterParameter='LightGreen|Orange'}"/>

            </StackPanel>
        </Border>

        <!-- Image selection + import -->
        <Border Style="{StaticResource CommonBorderStyle}">
            <StackPanel Margin="5 5" Orientation="Vertical">

                <Grid Margin="0 0 0 5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" VerticalAlignment="Center" Content="Image File:" Margin="0 0 5 0"/>

                    <TextBox Grid.Column="1"
                             VerticalAlignment="Center"
                             Text="{Binding ViewModel.SelectedImagePath}"
                             IsReadOnly="True"
                             mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                             Background="{DynamicResource MahApps.Brushes.AccentBase}"
                             BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"/>

                    <Button Grid.Column="2"
                            Content="Browse..."
                            IsEnabled="{Binding ViewModel.UiElementsEnabled, Mode=OneWay}"
                            BorderThickness="0"
                            Margin="5 0 0 0"
                            VerticalAlignment="Center"
                            mah:ControlsHelper.FocusBorderThickness="0"
                            mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                            Background="{DynamicResource MahApps.Brushes.AccentBase}"
                            BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                            Command="{Binding ViewModel.SelectImageCommand}"/>
                </Grid>

                <Button Content="Import Image to Livery"
                        IsEnabled="{Binding ViewModel.PainterInitialized, Mode=OneWay}"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        mah:ControlsHelper.FocusBorderThickness="0"
                        mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                        Background="{DynamicResource MahApps.Brushes.AccentBase}"
                        BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                        Command="{Binding ViewModel.ImportImageCommand}"/>

            </StackPanel>
        </Border>

        <!-- Progress -->
        <Border Style="{StaticResource CommonBorderStyle}">
            <StackPanel Margin="5 5" Orientation="Vertical">

                <ProgressBar Value="{Binding ViewModel.ImportProgress, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="8"
                             Margin="0 0 0 4"
                             mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"/>

                <Label Content="{Binding ViewModel.ImportStatus, Mode=OneWay}"
                       HorizontalAlignment="Center"
                       Foreground="LightGray"/>

            </StackPanel>
        </Border>

        <!-- Vinyl count + controls -->
        <Border Style="{StaticResource CommonBorderStyle}">
            <StackPanel Margin="5 0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Label VerticalAlignment="Center" Content="Vinyl Layers:" Margin="0 0 5 0"/>

                <Label VerticalAlignment="Center"
                       Content="{Binding ViewModel.CurrentVinylCount}"
                       FontWeight="Bold"
                       Margin="0 0 3 0"/>

                <Label VerticalAlignment="Center" Content="/" Margin="0 0 3 0"/>

                <Label VerticalAlignment="Center"
                       Content="{Binding ViewModel.MaxVinylLayers}"
                       Margin="0 0 10 0"/>

                <Button Content="Refresh"
                        IsEnabled="{Binding ViewModel.PainterInitialized, Mode=OneWay}"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        mah:ControlsHelper.FocusBorderThickness="0"
                        mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                        Background="{DynamicResource MahApps.Brushes.AccentBase}"
                        BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                        Command="{Binding ViewModel.RefreshVinylCountCommand}"/>

                <Rectangle Margin="4 8" Width="1" VerticalAlignment="Stretch" Fill="White"/>

                <Button Content="Clear All Vinyls"
                        IsEnabled="{Binding ViewModel.PainterInitialized, Mode=OneWay}"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        mah:ControlsHelper.FocusBorderThickness="0"
                        mah:ControlsHelper.CornerRadius="{StaticResource ControlCornerRadius}"
                        Background="{DynamicResource MahApps.Brushes.AccentBase}"
                        BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                        Command="{Binding ViewModel.ClearAllVinylsCommand}"/>

            </StackPanel>
        </Border>

    </StackPanel>
</Page>
